//Algoritmo
//Solicitar al usuario un número entero
Algoritmo NumPosNumNeg
	Definir num Como Entero
	Escribir Sin Saltar "Dime un número entero: "
	Leer num
	
	//Condición
	Si num >= 0 Entonces
		Escribir "El número es POSITIVO"
	SiNo
		Escribir "El número es NEGATIVO"
	Fin Si
	
FinAlgoritmo
